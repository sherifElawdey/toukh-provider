#!/usr/bin/env bash
# Copy to run_with_twilio.sh (gitignored), fill in values from Twilio Console.
set -euo pipefail
cd "$(dirname "$0")/.."

: "${TWILIO_ACCOUNT_SID:?Set TWILIO_ACCOUNT_SID}"
: "${TWILIO_AUTH_TOKEN:?Set TWILIO_AUTH_TOKEN}"
: "${TWILIO_VERIFY_SERVICE_SID:?Set TWILIO_VERIFY_SERVICE_SID}"

flutter run \
  --dart-define=TWILIO_ACCOUNT_SID="$TWILIO_ACCOUNT_SID" \
  --dart-define=TWILIO_AUTH_TOKEN="$TWILIO_AUTH_TOKEN" \
  --dart-define=TWILIO_VERIFY_SERVICE_SID="$TWILIO_VERIFY_SERVICE_SID" \
  "$@"
